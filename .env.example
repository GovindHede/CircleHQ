# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# TELEGRAM_BOT_TOKEN: Your Telegram bot API key from @BotFather
TELEGRAM_BOT_TOKEN=


# SUPABASE_URL: Your Supabase project URL (e.g., https://xyz.supabase.co)
SUPABASE_URL=

# SUPABASE_SERVICE_ROLE_KEY: The "service_role" secret key from Supabase
SUPABASE_SERVICE_ROLE_KEY=

# SUPABASE_ANON_KEY: The public "anon" key from Supabase
SUPABASE_ANON_KEY=

# APP_URL: The base URL where your server is hosted (needed for webhooks)
APP_URL=

# PORT: The port your server runs on (defaults to 3000)
PORT=3000

# NODE_ENV: Set to "production" for production deployment
NODE_ENV=production
